{
  "info": {
    "name": "Account Service",
    "description": "Microservice for managing bank accounts: savings, checking, fixed-term deposits, deposits, withdrawals, and transfers.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8082"
    }
  ],
  "item": [
    {
      "name": "Create Account",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": {
            "accountType": "SAVINGS",
            "customerId": "60f1a2b3c4d5e6f7a8b9c0d1",
            "balance": 1000.00,
            "currency": "PEN",
            "minOpeningAmount": 0.00,
            "monthlyMovementLimit": 6,
            "maintenanceFee": 0.00,
            "maxTransactionsNoFee": 5,
            "transactionFee": 5.00
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/accounts",
          "host": ["{{baseUrl}}"],
          "path": ["api", "accounts"]
        }
      }
    },
    {
      "name": "Find All Accounts",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/accounts",
          "host": ["{{baseUrl}}"],
          "path": ["api", "accounts"]
        }
      }
    },
    {
      "name": "Find Account by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/accounts/{{accountId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "accounts", "{{accountId}}"]
        }
      }
    },
    {
      "name": "Update Account",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": {
            "accountType": "SAVINGS",
            "customerId": "60f1a2b3c4d5e6f7a8b9c0d1",
            "balance": 1500.00,
            "currency": "PEN",
            "minOpeningAmount": 0.00,
            "monthlyMovementLimit": 6,
            "maintenanceFee": 0.00,
            "maxTransactionsNoFee": 5,
            "transactionFee": 5.00
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/accounts/{{accountId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "accounts", "{{accountId}}"]
        }
      }
    },
    {
      "name": "Delete Account",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/accounts/{{accountId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "accounts", "{{accountId}}"]
        }
      }
    },
    {
      "name": "Deposit",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": {
            "amount": 500.00,
            "description": "Cash deposit"
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/accounts/{{accountId}}/deposit",
          "host": ["{{baseUrl}}"],
          "path": ["api", "accounts", "{{accountId}}", "deposit"]
        }
      }
    },
    {
      "name": "Withdraw",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": {
            "amount": 200.00,
            "description": "ATM withdrawal"
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/accounts/{{accountId}}/withdraw",
          "host": ["{{baseUrl}}"],
          "path": ["api", "accounts", "{{accountId}}", "withdraw"]
        }
      }
    },
    {
      "name": "Find Accounts by Customer",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/accounts/customer/{{customerId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "accounts", "customer", "{{customerId}}"]
        }
      }
    }
  ]
}
