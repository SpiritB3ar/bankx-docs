{
  "info": {
    "name": "Credit Service",
    "description": "Microservice for managing credit products: personal loans, corporate loans, credit card charges, payments, and third-party payments.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8083"
    }
  ],
  "item": [
    {
      "name": "Create Credit",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": {
            "creditType": "PERSONAL_LOAN",
            "customerId": "60f1a2b3c4d5e6f7a8b9c0d1",
            "amount": 10000.00,
            "currency": "PEN",
            "interestRate": 0.015,
            "termMonths": 24,
            "monthlyPayment": 500.00,
            "outstandingBalance": 10000.00,
            "status": "ACTIVE",
            "dueDate": "2026-08-15"
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/credits",
          "host": ["{{baseUrl}}"],
          "path": ["api", "credits"]
        }
      }
    },
    {
      "name": "Find All Credits",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/credits",
          "host": ["{{baseUrl}}"],
          "path": ["api", "credits"]
        }
      }
    },
    {
      "name": "Find Credit by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/credits/{{creditId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "credits", "{{creditId}}"]
        }
      }
    },
    {
      "name": "Update Credit",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": {
            "creditType": "PERSONAL_LOAN",
            "customerId": "60f1a2b3c4d5e6f7a8b9c0d1",
            "amount": 10000.00,
            "currency": "PEN",
            "interestRate": 0.015,
            "termMonths": 24,
            "monthlyPayment": 500.00,
            "outstandingBalance": 9500.00,
            "status": "ACTIVE",
            "dueDate": "2026-08-15"
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/credits/{{creditId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "credits", "{{creditId}}"]
        }
      }
    },
    {
      "name": "Delete Credit",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/credits/{{creditId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "credits", "{{creditId}}"]
        }
      }
    },
    {
      "name": "Charge Credit Card",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": {
            "amount": 150.00,
            "description": "Electronics purchase"
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/credits/{{creditId}}/charge",
          "host": ["{{baseUrl}}"],
          "path": ["api", "credits", "{{creditId}}", "charge"]
        }
      }
    },
    {
      "name": "Make Payment",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": {
            "amount": 500.00,
            "description": "Monthly payment"
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/credits/{{creditId}}/payment",
          "host": ["{{baseUrl}}"],
          "path": ["api", "credits", "{{creditId}}", "payment"]
        }
      }
    },
    {
      "name": "Third-Party Payment",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": {
            "amount": 300.00,
            "description": "Third-party payment from account 60f1a2b3c4d5e6f7a8b9c0d2",
            "sourceAccountId": "60f1a2b3c4d5e6f7a8b9c0d2"
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/credits/{{creditId}}/third-party-payment",
          "host": ["{{baseUrl}}"],
          "path": ["api", "credits", "{{creditId}}", "third-party-payment"]
        }
      }
    },
    {
      "name": "Find Credits by Customer",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/credits/customer/{{customerId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "credits", "customer", "{{customerId}}"]
        }
      }
    }
  ]
}
