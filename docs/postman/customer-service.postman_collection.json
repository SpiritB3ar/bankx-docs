{
  "info": {
    "name": "Customer Service",
    "description": "Microservice for managing bank customers (personal, corporate, VIP, PYME).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8089"
    }
  ],
  "item": [
    {
      "name": "Create Customer",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": {
            "name": "John Doe",
            "dni": "12345678",
            "email": "john.doe@email.com",
            "phone": "+51987654321",
            "address": "123 Main St, Lima",
            "customerType": "PERSONAL",
            "profile": "BASIC"
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/customers",
          "host": ["{{baseUrl}}"],
          "path": ["api", "customers"]
        }
      }
    },
    {
      "name": "Find All Customers",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/customers",
          "host": ["{{baseUrl}}"],
          "path": ["api", "customers"]
        }
      }
    },
    {
      "name": "Find Customer by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/customers/{{customerId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "customers", "{{customerId}}"]
        }
      }
    },
    {
      "name": "Update Customer",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": {
            "name": "John Doe Updated",
            "dni": "12345678",
            "email": "john.doe.updated@email.com",
            "phone": "+51987654321",
            "address": "456 New St, Lima",
            "customerType": "PERSONAL",
            "profile": "VIP"
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/customers/{{customerId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "customers", "{{customerId}}"]
        }
      }
    },
    {
      "name": "Delete Customer",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/customers/{{customerId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "customers", "{{customerId}}"]
        }
      }
    }
  ]
}
