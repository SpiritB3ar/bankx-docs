        </mxCell>
        <mxCell id="l5" value="4. credit-card-check-response: credit-service responds with hasActiveCreditCard (response producer exists, consumer pending)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;whiteSpace=wrap" vertex="1" parent="1">
