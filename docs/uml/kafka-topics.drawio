        <mxCell id="l2" value="1. debt-check-request: account-service sends customerId to credit-service to check overdue debt before account creation" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;whiteSpace=wrap" vertex="1" parent="1">
